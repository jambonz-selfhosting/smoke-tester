# jambonz cluster
JAMBONZ_API_URL=https://jambonz.me/api/v1
JAMBONZ_SIP_DOMAIN=sip.jambonz.me
# JAMBONZ_SIP_PROXY=                      # optional; defaults to JAMBONZ_SIP_DOMAIN

# ---- Account scope (verb tests) ----
# Tenant-scoped token. Required by every verb test for:
#   - placing outbound calls via POST /Calls
#   - provisioning per-test SIP users via /Clients (claimUAS in helpers_test.go)
#   - provisioning the Deepgram speech credential at TestMain (it-deepgram label)
#   - reading RecentCalls / Alerts / WebhookSecret
JAMBONZ_API_KEY=replace-with-your-account-token
JAMBONZ_ACCOUNT_SID=replace-with-your-account-sid

# ---- Service-provider scope (rest tests) ----
# Required by the rest tier for cross-account provisioning:
# Accounts CRUD, SP-scoped VoipCarriers, MsTeamsTenants, ServiceProviders read.
JAMBONZ_SP_API_KEY=replace-with-your-sp-token
JAMBONZ_SP_SID=replace-with-your-sp-sid

# ---- Webhook tunnel ----
# Required for Phase-2 (webhook) verb tests AND for Phase-1 status-callback
# delivery — without it, jambonz fires call_status_hook at example.invalid
# placeholders and feature-server logs flood with DNS errors.
NGROK_AUTHTOKEN=replace-with-your-ngrok-token
# NGROK_DOMAIN=                            # optional; reserved subdomain on ngrok

# ---- Deepgram (TTS + STT inside jambonz, AND offline transcript verification) ----
# At TestMain we provision a SpeechCredential on the account with this key
# under label `it-deepgram` so every verb test references
# `synthesizer: {vendor: "deepgram", label: "it-deepgram"}` and
# `recognizer:  {vendor: "deepgram", label: "it-deepgram"}`.
# The same key is used by internal/stt/ to upload recordings to Deepgram for
# "did the right words come out?" assertions.
DEEPGRAM_API_KEY=replace-with-your-deepgram-key

# ---- Deepseek (agent verb LLM) ----
# Passed inline as `agent.llm.auth.apiKey`, bypassing jambonz's database
# credential lookup. Without this, TestVerb_Agent_* skip cleanly.
DEEPSEEK_API_KEY=replace-with-your-deepseek-key

# ---- Environment capability ----
BEHIND_NAT=true
# PUBLIC_IP=                               # only needed for Carrier/Inbound SIP modes (ADR-0014)

# ---- Test-run knobs ----
# RUN_ID=                                  # defaults to a short hex id per process
# LOG_LEVEL=info                           # info | debug
# ORPHAN_TTL_HOURS=2
# CONTRACT_STRICT=true                     # schema violations fail tests (ADR-0015)
