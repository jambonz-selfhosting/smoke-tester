# jambonz cluster
JAMBONZ_API_URL=https://jambonz.me/api/v1

# ---- Service-provider scope (mandatory; the only persistent identity) ----
# TestMain provisions an ephemeral account under this SP for each test
# suite (verbs / rest), mints an account-scope ApiKey for it, and tears
# the account down at suite end. The harness never touches resources
# whose name doesn't start with `it-<runID>-`.
JAMBONZ_SP_API_KEY=replace-with-your-sp-token
JAMBONZ_SP_SID=replace-with-your-sp-sid

# ---- SIP transport (verb tests; mandatory) ----
# Public IP of the cluster's SBC. Verb tests dial this IP directly for
# all SIP traffic; the synthetic per-account sip_realm has no real DNS,
# so the harness installs a *net.Resolver in the SIP transport that
# answers it locally with this IP.
JAMBONZ_SBC_PUBLIC_IP=replace-with-your-sbc-ip
# Optional zone suffix for the synthetic sip_realm. Default "smoke.test".
# Must contain at least one dot.
# JAMBONZ_SIP_REALM_ZONE=smoke.test

# ---- Webhook tunnel (mandatory) ----
NGROK_AUTHTOKEN=replace-with-your-ngrok-token
# Optional reserved subdomain (paid ngrok plans).
# NGROK_DOMAIN=

# ---- Third-party (mandatory) ----
DEEPGRAM_API_KEY=replace-with-your-deepgram-key
DEEPSEEK_API_KEY=replace-with-your-deepseek-key

# ---- Test-run knobs ----
# RUN_ID=                       # short hex by default
# LOG_LEVEL=info                # info | debug
# ORPHAN_TTL_HOURS=2
# CONTRACT_STRICT=true          # schema violations fail tests (ADR-0015)
